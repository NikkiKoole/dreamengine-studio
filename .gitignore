build/
node_modules/
.DS_Store
*.DS_Store
.claude/

# stray profiler dump — profile-fleet.js writes build/perf.json; a root one is a misfire
/perf.json

# experimental: roadview / external-data carts (osm-roads.js output)
data/

# fetched Floorplanner plans (floorplanner.js)
data-tools/fmltools/cache/

# intermediate iconset (make-mac-icon.js output; the committed artifact is mac-app.icns)
tools/assets/mac-app.iconset/

# editor live screenshot (build artifact, never commit)
/screenshot.png

# generated press kits (press-kit.js output; a real publish flow would handle site/press/)
/site/press/
# make-gif output scratch (committed clips live in editor/public/clips + tools/clips)
/docs/media/
# per-app screenshot cache — regenerated by the Apps view 📸 action (tinyjam's stay committed as a flagship default)
/apps/*/screenshots/
# stray cart data blob (build artifact)
/cart.blob

# published gallery — its own public repo (NikkiKoole/dreamengine) since 2026-07-06;
# built locally by build-site.js, pushed by publish-cart.sh. See docs/guides/sharing.md.
site/

# App Store Connect API keys — never commit
*.p8
