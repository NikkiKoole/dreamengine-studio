# generated by xcodegen — never commit (regenerated by build.sh)
*.xcodeproj/
# xcodebuild derivedData / output
build/
# staged cart sources (cart.c + data headers), generated per target by build.sh —
# ignore everything under gen/ EXCEPT the committed default AppIcon catalog, so a
# manual Xcode build (which runs no staging script) still gets an app icon.
gen/*
!gen/Assets.xcassets/
# generated by xcodegen from project.yml (entitlements block / extension info plist)
*.entitlements
AU/Info.plist
# spike screenshots
snap*.png
# derived store spec (testflight.sh output)
project-store.yml
